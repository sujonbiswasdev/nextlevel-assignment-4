model Meal {
  id                String            @id @default(uuid())
  meals_name        String            @db.VarChar(100)
  description       String?
  image             String?
  price             Int
  isAvailable       Boolean           @default(true)
  dietaryPreference DietaryPreference @default(HALAL)
  providerId        String
  category_name     String
  cuisine           Cuisine           @default(BANGLEDESHI)
  status            MealsStatus       @default(APPROVED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  category          Category          @relation(fields: [category_name], references: [name], onDelete: Cascade)
  provider          ProviderProfile   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  orderitem         Orderitem[]
  reviews           Review[]

  @@map("meal")
}

enum DietaryPreference {
  HALAL
  VEGAN
  VEGETARIAN
  ANY
  GLUTEN_FREE
  KETO
  PALEO
  DAIRY_FREE
  NUT_FREE
  LOW_SUGAR
}

enum Cuisine {
  BANGLEDESHI
  ITALIAN
  CHINESE
  INDIAN
  MEXICAN
  THAI
  JAPANESE
  FRENCH
  MEDITERRANEAN
  AMERICAN
  MIDDLE_EASTERN
}

enum MealsStatus {
  PENDING
  APPROVED
  REJECTED
}
